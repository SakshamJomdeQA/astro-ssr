---
import Layout from "./Layout.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, tags, image } = post.data;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const updatedFormatted = updatedDate?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const readingTime = Math.ceil(post.body.split(/\s+/).length / 200);
---

<Layout title={title} description={description} image={image} activeNav="/blog">
  <article style="max-width: 760px; margin: 0 auto; padding: 3rem 1.5rem 5rem;">
    <!-- Back link -->
    <a
      href="/blog"
      style="display: inline-flex; align-items: center; gap: 0.4rem; color: var(--color-text-muted); font-size: 0.875rem; margin-bottom: 2.5rem; transition: color 0.2s;"
      class="back-link"
    >
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
      All Posts
    </a>

    <!-- Tags -->
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem;">
      {tags.map(tag => (
        <span class="badge" style="background: var(--color-surface-2); color: var(--color-text-muted); border-color: var(--color-border); font-size: 0.7rem;">
          #{tag}
        </span>
      ))}
    </div>

    <!-- Title -->
    <h1 transition:name={`post-title-${post.slug}`} style="color: #fff; font-size: clamp(1.75rem, 4vw, 2.75rem); line-height: 1.2; margin-bottom: 1.5rem;">
      {title}
    </h1>

    <!-- Meta -->
    <div style="display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; color: var(--color-text-muted); font-size: 0.85rem; margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid var(--color-border);">
      <span style="display: flex; align-items: center; gap: 0.4rem;">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
        </svg>
        {author}
      </span>
      <span style="display: flex; align-items: center; gap: 0.4rem;">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      </span>
      {updatedDate && (
        <span style="display: flex; align-items: center; gap: 0.4rem; font-style: italic;">
          Updated: {updatedFormatted}
        </span>
      )}
      <span style="display: flex; align-items: center; gap: 0.4rem;">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        {readingTime} min read
      </span>
    </div>

    <!-- Hero image -->
    {image && (
      <img
        src={image}
        alt={title}
        transition:name={`post-image-${post.slug}`}
        style="width: 100%; height: 320px; object-fit: cover; border-radius: var(--radius-lg); margin-bottom: 2.5rem; border: 1px solid var(--color-border);"
        loading="eager"
      />
    )}

    <!-- Content -->
    <div class="prose">
      <slot />
    </div>

    <!-- Back to blog -->
    <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--color-border);">
      <a href="/blog" class="btn btn-outline">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
        Back to all posts
      </a>
    </div>
  </article>
</Layout>

<style>
  .back-link:hover { color: var(--color-primary-light); }
</style>
