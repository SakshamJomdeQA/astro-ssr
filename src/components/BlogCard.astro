---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDate, tags, image, featured } = post.data;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});

const readingTime = Math.ceil(post.body.split(/\s+/).length / 200);
const isMdx = post.id.endsWith(".mdx");
---

<a href={`/blog/${post.slug}`} class="blog-card">
  {image && (
    <div class="blog-card-image">
      <img
        src={image}
        alt={title}
        transition:name={`post-image-${post.slug}`}
        loading="lazy"
      />
      {featured && <span class="featured-badge">⭐ Featured</span>}
      {isMdx && <span class="mdx-badge badge badge-mdx" style="position: absolute; top: 0.75rem; right: 0.75rem;">MDX</span>}
    </div>
  )}
  <div class="blog-card-body">
    <div class="blog-card-tags">
      {tags.slice(0, 3).map(tag => (
        <span class="tag">#{tag}</span>
      ))}
    </div>
    <h3 transition:name={`post-title-${post.slug}`}>{title}</h3>
    <p class="blog-card-desc">{description}</p>
    <div class="blog-card-meta">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      <span>{readingTime} min read</span>
    </div>
  </div>
</a>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all 0.25s;
    box-shadow: var(--shadow-card);
    color: var(--color-text);
    text-decoration: none;
  }
  .blog-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-glow), var(--shadow-card);
    transform: translateY(-3px);
    color: var(--color-text);
  }

  .blog-card-image {
    position: relative;
    height: 200px;
    overflow: hidden;
  }
  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .blog-card:hover .blog-card-image img {
    transform: scale(1.05);
  }

  .featured-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: rgba(245, 158, 11, 0.9);
    color: #000;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    backdrop-filter: blur(4px);
  }

  .blog-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .blog-card-body h3 {
    font-size: 1.1rem;
    color: #fff;
    line-height: 1.4;
  }

  .blog-card-desc {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.6;
    flex: 1;
  }

  .blog-card-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }
</style>
