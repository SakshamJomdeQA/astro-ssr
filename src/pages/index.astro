---
// This page is SSG (statically generated at build time)
import Layout from "../layouts/Layout.astro";
import FeatureCard from "../components/FeatureCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const featuredPosts = allPosts
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const buildTime = new Date().toISOString();

const features = [
  {
    title: "Static Site Generation",
    description: "Pages pre-rendered at build time into plain HTML. Zero server overhead, served from CDN. Optimal Core Web Vitals and SEO.",
    icon: "⚡",
    badge: "SSG",
    badgeClass: "badge-ssg",
    href: "/blog/astro-ssg-guide",
    color: "var(--color-ssg)",
  },
  {
    title: "Server-Side Rendering",
    description: "Pages rendered on every request. Access cookies, headers, query params, and live data. Opt-in per page in hybrid mode.",
    icon: "🖥️",
    badge: "SSR",
    badgeClass: "badge-ssr",
    href: "/ssr",
    color: "var(--color-ssr)",
  },
  {
    title: "Islands Architecture",
    description: "Interactive React components hydrated in isolation — the rest of the page ships zero JS. Full framework interop.",
    icon: "🏝️",
    badge: "Islands",
    badgeClass: "badge-island",
    href: "/islands",
    color: "var(--color-island)",
  },
  {
    title: "API Routes",
    description: "File-based REST endpoints alongside your pages. Support GET, POST, PUT, DELETE. Runs server-side with full Node.js access.",
    icon: "🔌",
    badge: "API Routes",
    badgeClass: "badge-api",
    href: "/api-demo",
    color: "var(--color-api)",
  },
  {
    title: "Content Collections",
    description: "Type-safe, schema-validated Markdown & MDX content with Zod. Full TypeScript IntelliSense for all frontmatter fields.",
    icon: "📚",
    badge: "MDX",
    badgeClass: "badge-mdx",
    href: "/blog",
    color: "#fc8181",
  },
  {
    title: "Middleware",
    description: "Intercept every request before it reaches the page. Inject locals, log requests, set response headers, handle auth.",
    icon: "🔒",
    badge: "Middleware",
    badgeClass: "badge-ssr",
    href: "/middleware-demo",
    color: "var(--color-primary)",
  },
  {
    title: "View Transitions",
    description: "Built-in SPA-like page animations using the native browser View Transitions API. No client-side router required.",
    icon: "✨",
    badge: "SSG",
    badgeClass: "badge-ssg",
    href: "/blog/astro-view-transitions",
    color: "#60a5fa",
  },
  {
    title: "Image Optimization",
    description: "Automatic responsive images with <Image /> and <Picture />. Lazy loading, format conversion, and remote image support.",
    icon: "🖼️",
    badge: "SSG",
    badgeClass: "badge-ssg",
    href: "/features#images",
    color: "#f472b6",
  },
  {
    title: "Sitemap & SEO",
    description: "Auto-generated XML sitemap via @astrojs/sitemap. Open Graph meta tags, canonical URLs, and structured data ready.",
    icon: "🗺️",
    badge: "SSG",
    badgeClass: "badge-ssg",
    href: "/sitemap-index.xml",
    color: "#34d399",
  },
];
---

<Layout title="Home">
  <!-- Hero -->
  <section
    style="min-height: 85vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 4rem 1.5rem; position: relative; overflow: hidden;"
  >
    <!-- Background glows -->
    <div style="position: absolute; inset: 0; pointer-events: none; overflow: hidden;">
      <div style="position: absolute; top: -20%; left: 50%; transform: translateX(-50%); width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(124,58,237,0.12) 0%, transparent 70%);"></div>
      <div style="position: absolute; bottom: -10%; right: 10%; width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(6,182,212,0.08) 0%, transparent 70%);"></div>
    </div>

    <div style="max-width: 800px; position: relative; z-index: 1;">
      <div class="badge badge-ssr" style="margin-bottom: 1.5rem; font-size: 0.8rem;">
        🚀 Deployed on Contentstack Launch
      </div>
      <h1 style="color: #fff; margin-bottom: 1.5rem; background: linear-gradient(135deg, #fff 40%, var(--color-primary-light)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
        Astro Feature Showcase
      </h1>
      <p style="font-size: 1.2rem; color: var(--color-text-muted); margin-bottom: 2.5rem; max-width: 60ch; margin-left: auto; margin-right: auto;">
        A comprehensive demonstration of every major Astro feature — SSR, SSG, Islands, Content Collections, API Routes, Middleware, View Transitions, and more.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/features" class="btn btn-primary">Explore Features →</a>
        <a href="/blog" class="btn btn-outline">Read the Docs</a>
      </div>

      <!-- Build info badge -->
      <div style="margin-top: 3rem; display: inline-flex; align-items: center; gap: 0.6rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-full); padding: 0.4rem 1rem; font-size: 0.78rem; color: var(--color-text-muted);">
        <span style="width: 6px; height: 6px; background: var(--color-ssg); border-radius: 50%; display: inline-block; box-shadow: 0 0 6px var(--color-ssg);"></span>
        This page was statically generated at: <code style="font-size: 0.75rem;">{buildTime}</code>
      </div>
    </div>
  </section>

  <!-- Feature grid -->
  <section class="section" style="padding-top: 2rem;">
    <div class="container">
      <div class="text-center mb-4">
        <h2 style="color: #fff;">Everything Astro Can Do</h2>
        <p class="text-muted mt-1" style="margin: 0.75rem auto 0;">
          Click any card to see a live demo or read the in-depth guide.
        </p>
      </div>
      <div class="grid-3">
        {features.map((f) => <FeatureCard {...f} />)}
      </div>
    </div>
  </section>

  <!-- Rendering modes comparison -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="glow-divider"></div>
      <div class="text-center mb-4">
        <h2 style="color: #fff;">Hybrid Rendering at a Glance</h2>
        <p class="text-muted mt-1" style="margin: 0.75rem auto 0;">
          This project uses <code>output: "hybrid"</code> — pages are SSG by default, with per-page SSR opt-in.
        </p>
      </div>
      <div class="grid-2">
        <div class="card" style="border-color: rgba(16,185,129,0.3);">
          <div class="badge badge-ssg mb-2">⚡ SSG Pages</div>
          <h3 style="color: var(--color-ssg); margin-bottom: 0.75rem;">Pre-rendered at Build</h3>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.5rem; color: var(--color-text-muted); font-size: 0.9rem;">
            <li>✅ <code>/</code> — Home page</li>
            <li>✅ <code>/features</code> — Feature overview</li>
            <li>✅ <code>/about</code> — About page</li>
            <li>✅ <code>/blog</code> — Blog index</li>
            <li>✅ <code>/blog/[slug]</code> — Blog posts</li>
            <li>✅ <code>/islands</code> — Islands demo</li>
            <li>✅ <code>/sitemap-index.xml</code> — Sitemap</li>
          </ul>
        </div>
        <div class="card" style="border-color: rgba(124,58,237,0.3);">
          <div class="badge badge-ssr mb-2">🖥️ SSR Pages</div>
          <h3 style="color: var(--color-primary-light); margin-bottom: 0.75rem;">Rendered per Request</h3>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.5rem; color: var(--color-text-muted); font-size: 0.9rem;">
            <li>🔄 <code>/ssr</code> — Live server data</li>
            <li>🔄 <code>/ssr/user/[id]</code> — Dynamic SSR routes</li>
            <li>🔄 <code>/api-demo</code> — API demo page</li>
            <li>🔄 <code>/middleware-demo</code> — Middleware data</li>
            <li>🔌 <code>/api/hello</code> — REST endpoint</li>
            <li>🔌 <code>/api/time</code> — Real-time data</li>
            <li>🔌 <code>/api/echo</code> — Echo endpoint</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured posts -->
  {featuredPosts.length > 0 && (
    <section class="section" style="padding-top: 0; padding-bottom: 5rem;">
      <div class="container">
        <div class="glow-divider"></div>
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
          <h2 style="color: #fff;">Featured Posts</h2>
          <a href="/blog" class="btn btn-outline" style="font-size: 0.875rem;">All posts →</a>
        </div>
        <div class="grid-3">
          {featuredPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="card" style="display: flex; flex-direction: column; gap: 0.75rem; text-decoration: none; color: var(--color-text);">
              {post.data.image && (
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  style="width: 100%; height: 160px; object-fit: cover; border-radius: var(--radius-md); border: 1px solid var(--color-border);"
                  loading="lazy"
                />
              )}
              <h3 style="font-size: 1rem; color: #fff;">{post.data.title}</h3>
              <p style="font-size: 0.85rem; color: var(--color-text-muted); flex: 1;">{post.data.description}</p>
              <span style="font-size: 0.8rem; color: var(--color-primary-light);">Read more →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
