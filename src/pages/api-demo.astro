---
// SSR — we need server data (request ID, etc.) + the ApiTester is client:load
export const prerender = false;

import Layout from "../layouts/Layout.astro";
import ApiTester from "../components/ApiTester.tsx";

const { requestId } = Astro.locals;
---

<Layout title="API Routes Demo" description="Test Astro's file-based API routes live — GET, POST, and dynamic endpoints.">
  <div class="container" style="padding: 4rem 1.5rem 5rem; max-width: 900px;">
    <!-- Header -->
    <div style="margin-bottom: 3rem;">
      <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.5rem;">
        <span class="badge badge-api">🔌 API Routes</span>
        <span class="badge badge-island">⚛️ React Island</span>
        <span class="badge badge-ssr">🖥️ SSR Page</span>
      </div>
      <h1 style="color: #fff; margin-bottom: 1rem;">API Routes Demo</h1>
      <p style="color: var(--color-text-muted); font-size: 1.05rem; max-width: 65ch;">
        Astro supports file-based REST endpoints alongside pages. Click the buttons below to call them from this React island component.
      </p>
    </div>

    <!-- Interactive tester (React Island) -->
    <div class="card" style="margin-bottom: 2rem; border-color: rgba(6,182,212,0.3);">
      <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
        <h2 style="font-size: 1.1rem; color: #fff; margin: 0;">Live API Tester</h2>
        <span class="badge badge-island">client:load</span>
      </div>
      <ApiTester client:load />
    </div>

    <!-- Endpoint reference -->
    <h2 style="color: #fff; margin-bottom: 1.25rem; font-size: 1.2rem;">Available Endpoints</h2>
    <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2.5rem;">
      {[
        {
          method: "GET",
          path: "/api/hello",
          desc: "Returns a greeting with server metadata — request ID, runtime, timestamp.",
          color: "#10b981",
        },
        {
          method: "GET",
          path: "/api/time",
          desc: "Returns the current server time. Supports ?tz=America/New_York timezone param.",
          color: "#10b981",
        },
        {
          method: "GET",
          path: "/api/echo",
          desc: "Echoes back all query parameters and request headers.",
          color: "#10b981",
        },
        {
          method: "POST",
          path: "/api/echo",
          desc: "Echoes back the JSON request body. Send any payload.",
          color: "#f59e0b",
        },
      ].map(ep => (
        <div class="card" style="flex-direction: row; display: flex; align-items: flex-start; gap: 1rem; flex-wrap: wrap; border-color: var(--color-border);">
          <span style={`font-size: 0.7rem; font-weight: 700; color: ${ep.color}; background: ${ep.color}18; border: 1px solid ${ep.color}44; padding: 0.2rem 0.6rem; border-radius: 6px; white-space: nowrap; margin-top: 0.1rem;`}>
            {ep.method}
          </span>
          <div style="flex: 1;">
            <code style="color: var(--color-accent-light); font-size: 0.9rem;">{ep.path}</code>
            <p style="color: var(--color-text-muted); font-size: 0.85rem; margin: 0.4rem 0 0;">{ep.desc}</p>
          </div>
          <a href={ep.path} target="_blank" rel="noopener" class="btn btn-outline" style="font-size: 0.75rem; white-space: nowrap;" aria-label={`Open ${ep.path} in new tab`}>
            Open ↗
          </a>
        </div>
      ))}
    </div>

    <!-- Code example -->
    <div class="card" style="border-color: rgba(6,182,212,0.3);">
      <h3 style="color: #fff; margin-bottom: 1rem; font-size: 1rem;">📄 Creating an API Route</h3>
      <pre style="margin: 0; font-size: 0.8rem;"><code>// src/pages/api/hello.ts
import type &#123; APIRoute &#125; from "astro";

export const prerender = false; // always SSR for API routes

export const GET: APIRoute = async (&#123; locals, request &#125;) => &#123;
  const data = &#123;
    message: "Hello from Astro!",
    requestId: locals.requestId, // from middleware
    timestamp: new Date().toISOString(),
  &#125;;

  return new Response(JSON.stringify(data), &#123;
    status: 200,
    headers: &#123; "Content-Type": "application/json" &#125;,
  &#125;);
&#125;;

export const POST: APIRoute = async (&#123; request &#125;) => &#123;
  const body = await request.json();
  // ...handle POST
&#125;;
</code></pre>
    </div>

    <div style="margin-top: 1.5rem; padding: 1rem; background: rgba(124,58,237,0.06); border-radius: var(--radius-md); border: 1px solid rgba(124,58,237,0.2); font-size: 0.85rem; color: var(--color-text-muted);">
      🔍 Current server request ID: <code>{requestId}</code> — injected by middleware into <code>Astro.locals</code>
    </div>
  </div>
</Layout>
